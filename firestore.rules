rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read their own profile. All writes that change plan/credits
    // happen server-side via the Admin SDK (which bypasses these rules),
    // so the client is never allowed to write billing fields directly.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
