rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      // User cannot change their plan, and credits can only decrease
      // (one-time free credits, never topped up client-side).
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.credits <= resource.data.credits;
      allow delete: if false;
    }
  }
}
